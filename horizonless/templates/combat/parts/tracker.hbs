<div class="horizonless-tracker-shell">
  <ol id="combat-tracker" class="combat-tracker directory-list">
    {{#each turns}}
      <li
        class="combatant actor directory-item flexrow {{this.css}} {{#if this.isTakingTurn}}horizonless-taking-turn{{/if}}"
        data-combatant-id="{{this.id}}"
      >
        <img class="token-image" src="{{this.img}}" alt="{{this.name}}" loading="lazy">

        <div class="token-name flexcol">
          <h4>{{this.name}}</h4>
          <div class="combatant-controls flexrow">
            {{#if ../enable_initiative}}
              {{#if this.hasRolled}}
                <span class="initiative">{{this.initiative}}</span>
              {{else if this.owner}}
                <a
                  class="combatant-control"
                  aria-label="{{localize 'COMBAT.InitiativeRoll'}}"
                  role="button"
                  data-tooltip="COMBAT.InitiativeRoll"
                  data-action="rollInitiative"
                >
                  <i class="fas fa-dice-d20"></i>
                </a>
              {{/if}}
            {{/if}}

            {{#if ../user.isGM}}
              <a
                class="combatant-control {{#if this.hidden}}active{{/if}}"
                aria-label="{{localize 'COMBAT.ToggleVis'}}"
                role="button"
                data-tooltip="COMBAT.ToggleVis"
                data-action="toggleHidden"
              >
                <i class="fas fa-eye-slash"></i>
              </a>
              <a
                class="combatant-control {{#if this.defeated}}active{{/if}}"
                aria-label="{{localize 'COMBAT.ToggleDead'}}"
                role="button"
                data-tooltip="COMBAT.ToggleDead"
                data-action="toggleDefeated"
              >
                <i class="fas fa-skull"></i>
              </a>
            {{/if}}

            {{#if this.canPing}}
              <a
                class="combatant-control"
                aria-label="{{localize 'COMBAT.PingCombatant'}}"
                role="button"
                data-tooltip="COMBAT.PingCombatant"
                data-action="pingCombatant"
              >
                <i class="fa-solid fa-bullseye-arrow"></i>
              </a>
            {{/if}}

            {{#unless ../user.isGM}}
              <a
                class="combatant-control"
                aria-label="{{localize 'COMBAT.PanToCombatant'}}"
                role="button"
                data-tooltip="COMBAT.PanToCombatant"
                data-action="panToCombatant"
              >
                <i class="fa-solid fa-arrows-to-eye"></i>
              </a>
            {{/unless}}

            <span
              class="horizonless-activations"
              data-tooltip="{{localize 'HORIZONLESS_RPG.Combat.ActivationCount'}}"
            >
              <i class="fas fa-bolt"></i>
              <span>{{this.activations}}</span>
            </span>

            <div class="token-effects">
              {{#each this.effects.icons}}
                <img class="token-effect" src="{{this.img}}" alt="{{this.name}}">
              {{/each}}
            </div>
          </div>
        </div>

        {{#if this.hasResource}}
          <div class="token-resource">
            <span class="resource">{{this.resource}}</span>
          </div>
        {{/if}}

        <div class="token-initiative horizonless-token-initiative">
          {{#unless this.isTakingTurn}}
            {{#horizonlessRepeat this.pending}}
              <a
                class="{{../../activate_icon_class}}"
                role="button"
                data-action="activateCombatant"
                data-tooltip="{{localize 'HORIZONLESS_RPG.Combat.ActivateTurn'}}"
              ></a>
            {{/horizonlessRepeat}}
          {{/unless}}

          {{#horizonlessRepeat this.finished}}
            <a
              class="{{../../deactivate_icon_class}} done"
              role="button"
              data-action="deactivateCombatant"
              data-tooltip="{{localize 'HORIZONLESS_RPG.Combat.EndTurn'}}"
            ></a>
          {{/horizonlessRepeat}}
        </div>
      </li>
    {{/each}}
  </ol>

  {{#unless isPopOut}}
    <div
      class="horizonless-tracker-resize-handle"
      data-tooltip="{{localize 'HORIZONLESS_RPG.Combat.ResizeTracker'}}"
    ></div>
  {{/unless}}
</div>
